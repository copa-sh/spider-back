# GitHub accounts
# Add as many numbered accounts as needed: GITHUB_ACCOUNT_1_*, GITHUB_ACCOUNT_2_*, etc.
GITHUB_ACCOUNT_1_TOKEN=ghp_replace_me
GITHUB_ACCOUNT_1_OWNER=your-github-user-or-org

# Optional additional account
# GITHUB_ACCOUNT_2_TOKEN=ghp_replace_me_too
# GITHUB_ACCOUNT_2_OWNER=another-user-or-org

# GitHub storage settings
GITHUB_BRANCH=main
GITHUB_UPLOADS_PREFIX=storage
GITHUB_REPOSITORY_PREFIX=data
GITHUB_REPOSITORY_PRIVATE=true
GITHUB_REPOSITORY_MAX_SIZE_KB=524288
GITHUB_ACCOUNT_DAILY_UPLOAD_LIMIT_GB=5
GITHUB_CHUNK_SIZE_MB=24
GITHUB_TIMEOUT_SECONDS=300
GITHUB_MAX_RETRY=3
GITHUB_BACKOFF_SECONDS=2
GITHUB_UPLOAD_SLEEP_MIN_SECONDS=0.25
GITHUB_UPLOAD_SLEEP_MAX_SECONDS=1.5

# Application paths and web server
APP_DATA_DIR=/datos
APP_STATE_DIR=/state
APP_WEB_HOST=0.0.0.0
APP_WEB_PORT=8080
APP_SYNC_INTERVAL_SECONDS=604800
APP_VERIFY_INTERVAL_SECONDS=604800

# Optional: if omitted, the app generates and persists them in /state/secrets.json
# APP_WEB_PIN=12345678
# APP_ENCRYPTION_KEY=replace_with_base64url_key

# Docker Compose only
APP_DATA_BIND=/mnt/datos/timeline
GUNICORN_WORKERS=4
