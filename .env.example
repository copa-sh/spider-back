# GitHub accounts
# Add as many numbered accounts as needed: GITHUB_ACCOUNT_1_*, GITHUB_ACCOUNT_2_*, etc.
GITHUB_ACCOUNT_1_TOKEN=ghp_replace_me
GITHUB_ACCOUNT_1_OWNER=your-github-user-or-org

# Optional additional account
# GITHUB_ACCOUNT_2_TOKEN=ghp_replace_me_too
# GITHUB_ACCOUNT_2_OWNER=another-user-or-org

# GitHub storage settings
GITHUB_BRANCH=main
GITHUB_UPLOADS_PREFIX=storage
GITHUB_REPOSITORY_PREFIX=model
GITHUB_REPOSITORY_PRIVATE=true
GITHUB_REPOSITORY_MAX_SIZE_KB=524288
GITHUB_ACCOUNT_DAILY_UPLOAD_LIMIT_GB=5
GITHUB_CHUNK_SIZE_MB=24
GITHUB_TIMEOUT_SECONDS=300
GITHUB_MAX_RETRY=3
GITHUB_BACKOFF_SECONDS=2
GITHUB_UPLOAD_SLEEP_MIN_SECONDS=0.25
GITHUB_UPLOAD_SLEEP_MAX_SECONDS=1.5

# Telegram accounts (OPTIONAL second network — leave commented to use GitHub only)
# Requires `pyrogram` + `tgcrypto` installed. Get API_ID/API_HASH at my.telegram.org.
# Each account needs all three of API_ID, API_HASH and PHONE; account_id becomes tg_account_<n>.
# TG_ACCOUNT_1_API_ID=12345678
# TG_ACCOUNT_1_API_HASH=abcdef1234567890abcdef1234567890
# TG_ACCOUNT_1_PHONE=+34600000000
# TG_ACCOUNT_2_API_ID=87654321
# TG_ACCOUNT_2_API_HASH=0987654321098765432109876543210a
# TG_ACCOUNT_2_PHONE=+34600000001

# Telegram storage settings (only used when at least one TG account is defined)
# TG_CHANNEL_PREFIX=spider-model
# TG_CHANNEL_PRIVATE=true
# TG_TIMEOUT_SECONDS=900
# TG_MAX_RETRY=3
# TG_BACKOFF_SECONDS=2
# NOTE: the MTProto session file (tg_account_<n>.session) lives in APP_STATE_DIR
# (the /state volume). Generate it locally once (SMS code) and mount it so the
# container starts already authenticated.

# Copies per version — one per account across ALL networks (GitHub + Telegram).
# Must be <= the total number of configured accounts.
COPY_COUNT=1

# Application paths and web server
APP_DATA_DIR=/datos
APP_STATE_DIR=/state
APP_WEB_HOST=0.0.0.0
APP_WEB_PORT=8080
APP_SYNC_INTERVAL_SECONDS=604800
APP_VERIFY_INTERVAL_SECONDS=604800

# Optional: if omitted, the app generates and persists them in /state/secrets.json
# APP_WEB_PIN=12345678
# APP_ENCRYPTION_KEY=replace_with_base64url_key

# Docker Compose only
APP_DATA_BIND=/mnt/datos/timeline
APP_STATE_BIND=./state
GUNICORN_WORKERS=4
